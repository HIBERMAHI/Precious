doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Document
  link(rel='stylesheet' href='/css/precious.css')
  style.
    body {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0;
    height: auto;
    background: linear-gradient(to right, #010b1b, #011126);
    }
    label {
    text-align: left;
    margin: 10px 0px;
    font-size: 1.2rem;
    color: rgb(9, 9, 53);
    }
    input {
    height: 3rem;
    border-radius: 8px;
    }
    a {
    text-decoration: none;
    margin-left: 10px;
    font-size: 1.2rem;
    color: rgb(9, 9, 52);
    }
    button {
    width: 100%;
    height: 3rem;
    color: rgb(214, 208, 208);
    background-color: rgb(15, 15, 83);
    font-size: 1.5rem;
    border: none;
    border-radius: 12px;
    }
.card
  img.logo(src='/images/logo.png' width='50' height='50' alt='logo')
  h4 Singn In to get started
  p.para Sign up to get started
  form
    .part1
      label(for='email') Email
      input#email(type='email' name='email' placeholder='Enter Your Email' required='')
    .part1
      label(for='password') Password
      input#password(type='password' name='password' placeholder='Enter Password' required='')
    .check
      .remember
        input#checkbox(type='checkbox')
        label(for='checkbox') Remember me
      a(href='#') Forgot Password
    button(type='submit') Login
    .login
      | Don&apos;t have an account? 
      a(href='#') Sign Up
