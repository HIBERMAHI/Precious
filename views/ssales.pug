doctype html
head
  meta(charset='UTF-8')
  title Nyondo Sales Dashboard
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')
  link(rel='stylesheet' href='/css/ssales.css')
// SIDEBAR
.sidebar
  h2 &#x2692; NYONDO HARDWARE
  p Sales Attendant Panel
  a(href='ssales')
    i.fas.fa-home
    |  Dashboard
  a(href='newsale')
    i.fas.fa-cash-register
    |  New Sale
  a(href='stockview')
    i.fas.fa-box
    |  Stock View
  a(href='logout')
    i.fas.fa-sign-out-alt
    |  Logout
// MAIN
.main
  // TOP BAR + PROFILE
  .top-section
    .topbar
      h1 Sales Dashboard
      p Welcome back! Manage your daily sales efficiently.
    // PROFILE CARD
    .profile-card
      .avatar
        i.fas.fa-user
      .profile-info
        h3 Sales Attendant
        p John Doe
        span Active
  // SUMMARY CARDS (LOW STOCK REMOVED → 5 ITEMS LEFT)
  section.cards
    .card
      i.fas.fa-money-bill-wave
      h3 Today's Sales
      p #{stats.salesRevenue.toLocaleString()} UGX
    .card
      i.fas.fa-receipt
      h3 Transactions
      p #{stats.transactions.toLocaleString()}
    .card
      i.fas.fa-boxes-stacked
      h3 Items Sold
      p #{stats.itemsSold.toLocaleString()} Items
    .card
      i.fas.fa-file-invoice
      h3 Receipts
      p #{stats.receipts.toLocaleString()} Receipts
    
  // QUICK LINKS
  section.quick-links
    h2 Quick Actions
    .links
      a.link-box(href='newsale')
        i.fas.fa-plus
        |  New Sale
      a.link-box(href='stockview')
        i.fas.fa-boxes
        |  Check Stock
      a.link-box(href='receipt')
        i.fas.fa-receipt
        |  View Receipts
  // RECENT SALES
  section.recent-sales
    h2
      i.fas.fa-clock
      |  Recent Sales
    table
      thead
        tr
          th customerName
          th productName
          th quantity
          th price
          th PaymentMethod
          th Status
          th attendant 
          th totalAmount
          th Date
      tbody
        each sale in dbSales
         tr
            td #{sale.customerName}
            td #{sale.productName ? sale.productName.productName : 'Item deleted'}
            td #{sale.quantity}
            td #{sale.price}
            td #{sale.paymentMethod}
            td #{sale.status}
            td #{sale.attendant ? sale.attendant.fullname: 'Unknown'}
            td #{sale.totalAmount} UGX
             td #{new Date(sale.date).toLocaleString()}
        else 
          tr
            td.text-center(colspan='11') No sales have been recorded yet
          