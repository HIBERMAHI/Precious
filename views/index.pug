doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Nyondo Stock System
  // FONT AWESOME
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')
  // CSS
  link(rel='stylesheet' href='/css/precious.css')
// NAVBAR (SIMPLIFIED)
header.navbar
  .logo
    span.logo-icon N
    div
      h2 Nyondo
      small Stock System
  // ONLY ONE ACTION
  a.login-btn(href='login.html')
    i.fas.fa-sign-in-alt
    |  Login
// HERO SECTION
section.hero
  .overlay
  .hero-content
    span.tag Smart Stock Control for Hardware Stores
    h1
      | Stop Guessing Your Stock.
      br
      span Start Managing It Right.
    p
      | Nyondo helps you track inventory, monitor sales, manage debts,
      | and stay in control of your hardware business &mdash; all in one system.
    // BENEFITS
    .features
      div
        i.fas.fa-check-circle
        |  Real-time stock tracking
      div
        i.fas.fa-check-circle
        |  Credit &amp; debit management
      div
        i.fas.fa-check-circle
        |  Sales history &amp; reports
    // CTA
    .buttons
      a.btn.primary(href='login.html')
        i.fas.fa-sign-in-alt
        |  Access Your Dashboard
    // TRUST LINE
    small.trust
      | Trusted by hardware businesses to simplify stock management.
