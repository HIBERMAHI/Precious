doctype html
head
  meta(charset='UTF-8')
  title Nyondo Sales
  link(rel='stylesheet' href='/css/newsale.css')
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')

// SIDEBAR
.sidebar
  .logo
    | ⚒ NYONDO HARDWARE
  ul
    li
      a(href='ssales')
        i.fas.fa-home
        |   Dashboard
    li
      a(href='newsale')
        i.fas.fa-cash-register
        |   New Sale
    li
      a(href='stockview')
        i.fas.fa-box
        |   Stock View
    li
      a(href='logout')
        i.fas.fa-sign-out-alt
        |   Logout

// MAIN
.main
  h1 Sales Management

  // ================= NEW SALE =================
  section.sale-form
    h2 Register New Sale

    if error
      p#error-msg(style="color: white; background-color: #d9534f; padding: 12px; border-radius: 5px; margin-bottom: 20px; font-weight: bold; text-align: center; border: 1px solid #b94a48;") #{error}

    form(action='/newsale' method='post')
      .form-group
        label Customer Name
        input(type='text' name='customerName')

      .form-group
        label Phone Number
        input(type='text' name='phone')

      .form-group
        label Product Name
        select(name='productName' required)
          option(value='' disabled selected) Select product
          each product in items
            option(value=product._id)
              | #{product.productName} (quantity: #{product.quantity} | price:#{product.sellingPrice} UGX)

      .form-group
        label Quantity
        input(type='number' name='quantity' required='' min='1' )

      .form-group
        label Price (UGX)
        input(type='number' name='price' required='' )

      .form-group
        label Delivery Option
        select(name='deliveryOption')
          option(value='pickup') Pickup
          option(value='delivery') Delivery

      .form-group
        label Distance (km)
        input(type='number' name='distance')

      
      .form-group
        label Payment Method
        select(name='paymentMethod')
          option(value='cash') Cash
          option(value='mobile') Mobile Money
          option(value='bank') Bank

      .form-group
        label Status
        select(name='status' required)
          option(value='completed') Completed
          option(value='pending') Pending

      

      .button-group
        button.register-btn(type='submit')
          i.fas.fa-plus
          |   Register Sale
  // ================= RECENT SALES =================
  section.recent-sales
    h2 Recent Sales
    table
      thead
        tr
          th Client
          th Item
          th quantity
          th price
          th T.Fee
          th P.Method
          th status
          th T.Amount
          th attendant
          th date
          if user.role === "salesattendant" || user.role === "admin"
            th Actions
      tbody
        if dbSales && dbSales.length > 0
          each sale in dbSales
            tr
              td #{sale.customerName}
              td #{sale.productName ? sale.productName.productName : 'Item deleted'}
              td #{sale.quantity}
              td #{sale.price ? sale.price.toLocaleString() : '0'}
              td #{sale.transportFee ? sale.transportFee.toLocaleString() : '0'}
              td #{sale.paymentMethod}
              td #{sale.status}
              td #{sale.totalAmount ? sale.totalAmount.toLocaleString() : '0'}
              td #{sale.attendant ? sale.attendant.fullname : 'unknown'}
              td #{new Date(sale.date).toLocaleString()}
              if user.role === "salesattendant" || user.role === "admin"
                td
                  span.action-btns
                    //- NEW RECEIPT BUTTON
                    a.btn.btn-sm.btn-outline-primary(href=`/receipt/${sale._id}` title="View Receipt" style="margin-right: 5px;")
                      i.fas.fa-file-invoice
                    
                    //- EDIT BUTTON
                    a.btn.btn-sm-outline-warning(href=`/sale/edit/${sale._id}`)
                      i.fas.fa-edit
                    
                    //- DELETE BUTTON
                    form(action=`/delete/${sale._id}` method='post' onsubmit='return confirm("Are you sure you want to delete this sale")' style='display:inline;')
                      button.btn.btn-sm.btn-outline-danger(type='submit')
                        i.fas.fa-trash-alt
        else
          tr
            td.text-center(colspan='11') No sales have been recorded yet

  script.
    document.addEventListener('DOMContentLoaded', () => {
      const errorMsg = document.getElementById('error-msg');
      const allInputs = document.querySelectorAll('input, select');

      if (errorMsg) {
        allInputs.forEach(element => {
          element.addEventListener('input', () => {
            errorMsg.style.display = 'none';
          }, { once: true });
          
          element.addEventListener('change', () => {
            errorMsg.style.display = 'none';
          }, { once: true });
        });
      }
    });