doctype html
head
  meta(charset='UTF-8')
  title Nyondo Sales
  link(rel='stylesheet' href='/css/newsale.css')
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')
// SIDEBAR
.sidebar
  .logo
    |⚒ NYONDO HARDWARE
  ul
    li
      a(href='/dashboard')
        i.fas.fa-home
        |  Dashboard
    li
      a(href='/sales')
        i.fas.fa-cash-register
        |  Sales
    li
      a(href='/products')
        i.fas.fa-box
        |  Stock View
    li
      a(href='/receipts')
        i.fas.fa-receipt
        |  Credit Sales
    li
      a(href='/returns')
        i.fas.fa-rotate-left
        |  sales History
    li
      a(href='/logout')
        i.fas.fa-right-from-bracket
        |  Logout
// MAIN
.main
  h1 Sales Management
  // ================= NEW SALE =================
  section.sale-form
    h2 Register New Sale
    form(action=`/sale/edit/${sale._id}` method='post')
      .form-group
        label Customer Name
        input(type='text' value=sale.customerName  name='customerName')
      .form-group
        label Phone Number
        input(type='text' value=sale.phone  name='phone')
      .form-group
        label Quantity
        input(type='number' name='quantity' value=quantity  required='')
      .form-group
        label Price (UGX)
        input(type='number' name='price' value=price  required='')
        .form-group
        label Delivery Option
        select(name='deliveryOption')
          option(value='pickup' selected=sale.deliveryOption === 'pickup' ) Pickup
          option(value='delivery' selected=sale.deliveryOption === 'delivery' ) Delivery
        .form-group
        label Distance (km)
        input(type='number' value=distance   name='distance')
        .form-group
        label Transport Fee
        input(type='number' value=transportFee  name='transportFee' readonly='')
      .form-group
        label Total Amount
        input(type='number' value=totalAmount  name='totalAmount')
      .button-group
        button.register-btn(type='submit')
          i.fas.fa-plus
          |  Register Sale
        button.receipt-btn(type='button')
          i.fas.fa-receipt
          |  Issue Receipt
  // 