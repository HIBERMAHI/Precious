doctype html
html
  head
    meta(charset='UTF-8')
    title Inventory - Nyondo Hardware

    link(rel='stylesheet' href='/css/invento.css')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')

  body
    // SIDEBAR
    .sidebar
      .logo
        h2 &#x2692; NYONDO HARDWARE
      ul
        li
          a(href='storedash')
            i.fas.fa-home
            | Dashboard
        li.active
          a(href='invento')
            i.fas.fa-boxes
            | Inventory
        li
          a(href='storsales')
            i.fas.fa-cash-register
            | Sales
        li
          a(href='addstock')
            i.fas.fa-plus-circle
            | Add Stock
        li
          a(href='logout')
            i.fas.fa-sign-out-alt
            | Logout

    .main
      .header
        h1
          i.fas.fa-boxes
          | Inventory Overview

        .actions
          a.btn(href='/stock')
            i.fas.fa-plus
            | Add Stock
          button.btn.secondary
            i.fas.fa-file-export
            | Export

      .cards
        .card
          i.fas.fa-cubes
          div
            h3 Total Products
            p #{stats.totalProducts.toLocaleString()}

        .card.warn
          i.fas.fa-exclamation-triangle
          div
            h3 Low Stock
            p #{stats.lowStock.toLocaleString()}

        .card.danger
          i.fas.fa-times-circle
          div
            h3 Enough Stock
            p #{stats.enougthStock.toLocaleString()}

        .card.success
          i.fas.fa-coins
          div
            h3 Total Value
            p #{stats.inventoryValue.toLocaleString()} UGX

      .search-bar
        input(type='text' placeholder='Search product...')
        select
          option All
          option Low Stock
          option Out of Stock
          option In Stock

      .table-section
        table
          thead
            tr
              th Product Name
              th Image
              th Factory
              th Quantity
              th Buying Price
              th Selling Price
              th Supplier Name
              th Supplier Contact
              th Date
              th Payment Status  
              th Actions

          tbody
            if dbStock.length === 0
              tr
                td(colspan='11') No stock available

            each stock in dbStock
              tr
                td #{stock.productName}

                td
                  if stock.itemImage
                    img(src='/' + stock.itemImage width='50' height='50')
                  else
                    span no image

                td #{stock.factory}
                td #{stock.quantity}
                td #{stock.buyingPrice}
                td #{stock.sellingPrice}
                td #{stock.supplierName}
                td #{stock.supplierContact}
                td #{new Date(stock.deliveryDate).toLocaleString()}

                td
                  span.status(class=stock.paymentStatus)
                    | #{stock.paymentStatus || 'Pending'}

                td
                  .action-btns
                    a.btn.btn-sm.btn-outline-warning(href=`/stock/edit/${stock._id}`)
                      i.fas.fa-edit

                    form(action=`/deleted/${stock._id}` method='post' onsubmit='return confirm("Are you sure you want to delete stock?")')
                      button.btn.btn-sm.btn-outline-danger(type='submit')
                        i.fas.fa-trash-alt