doctype html
html
  head
    meta(charset='UTF-8')
    title Register Stock - Nyondo Hardware
    link(rel='stylesheet' href='/css/ssales.css')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')
  body
    // SIDEBAR
    .sidebar
      .logo
        h2 &#x2692; NYONDO HARDWARE
      ul
        li
          a(href='storedash')
            i.fas.fa-home
            span  Dashboard
        li
          a(href='invento')
            i.fas.fa-boxes
            span  Inventory
        li
          a(href='/sales')
            i.fas.fa-cash-register
            span  Sales
        li.active
          a(href='addstock')
            i.fas.fa-plus-circle
            span  Add Stock
        li
          a(href='logout')
            i.fas.fa-sign-out-alt
            span  Logout

    // MAIN
    .main
      .header
        h1
          i.fas.fa-plus-circle
          |  Stock Registration
        p Fill in the details to add new stock to inventory

      //- ERROR MESSAGE BOX
      if error
        div(style="background-color: #f8d7da; color: #721c24; padding: 15px; border: 1px solid #f5c6cb; border-radius: 5px; margin-bottom: 20px; font-weight: bold; text-align: center;")
          i.fas.fa-exclamation-circle
          |  #{error}

      // FORM
      form.stock-form(method='post' action='/addstock' enctype="multipart/form-data")
        h2 Product Details
        .grid
          .field
            label Product Name
            input(type='text' name='productName' value=(formData ? formData.productName : ''))
          .field
            label Category
            select(name='category' required='')
              option(value='') Select Category
              each cat in ['Building', 'Hardware', 'Electrical', 'Roofing', 'Timber']
                option(value=cat selected=(formData && formData.category === cat)) #{cat}

        h2 Stock Information
        .grid
          .field
            label Quantity
            input(type='number' name='quantity' required='' value=(formData ? formData.quantity : ''))
          .field
            label Unit
            select(name='unit')
              each unit in ['Bags', 'Pieces', 'Boxes', 'Litres']
                option(value=unit selected=(formData && formData.unit === unit)) #{unit}

        h2 Pricing
        .grid
          .field
            label Buying Price
            input(type='number' name='buyingPrice' required='' value=(formData ? formData.buyingPrice : ''))
          .field
            label Selling Price
            input(type='number' name='sellingPrice' required='' value=(formData ? formData.sellingPrice : ''))

        h2 Supplier Details
        .grid
          .field
            label Supplier Name
            input(type='text' name='supplierName' value=(formData ? formData.supplierName : ''))
          .field
            label Supplier Contact
            input(type='number' name='supplierContact' value=(formData ? formData.supplierContact : ''))
          .field
            label Image Uploads
            input(type='file' name='itemImage')

        .buttons
          button.btn.save(type='submit') Save Stock
          button.btn.reset(type='reset') Reset