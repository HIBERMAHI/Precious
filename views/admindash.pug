doctype html
html
  head
    meta(charset='UTF-8')
    title Nyondo Admin Dashboard

    link(rel='stylesheet' href='/css/admindash.css')

    link(
      rel='stylesheet'
      href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css'
    )

  body

    // ================= SIDEBAR =================
    .sidebar

      .logo
        h2 ⚒ NYONDO ADMIN

      ul.nav

        li.active
          a(href='/admin/dashboard')
            i.fas.fa-chart-line
            |  Dashboard

        li
          a(href='/inventory')
            i.fas.fa-boxes
            |  Inventory

        li
          a(href='/sales')
            i.fas.fa-cash-register
            |  Sales

        li
          a(href='/stock/add')
            i.fas.fa-plus-circle
            |  Add Stock

        li
          a(href='/deposits')
            i.fas.fa-piggy-bank
            |  Deposits

        li
          a(href='/transport')
            i.fas.fa-truck
            |  Transport

        li
          a(href='/users')
            i.fas.fa-users
            |  Users

        li
          a(href='/reports')
            i.fas.fa-chart-pie
            |  Reports

        li
          a(href='/logout')
            i.fas.fa-sign-out-alt
            |  Logout

    // ================= MAIN =================
    .main

      // ================= TOP BAR =================
      .topbar

        h1 Admin Dashboard

        .profile
          i.fas.fa-user-circle
          span Admin

      // ================= DASHBOARD CARDS =================
      .cards

        .card
          h3 Stock Expenditure
          p #{stats.inventoryValue.toLocaleString()} UGX

        .card.success
          h3 Total Sales Revenue
          p #{stats.salesRevenue.toLocaleString()} UGX

        .card
          h3 Total Users
          p 12

        .card.warn
          h3 Stock Alerts
          p 8 Items

      // ================= QUICK ACTIONS =================
      .section

        h2 Quick Actions

        .actions

          a.btn(href='/stock/add')
            i.fas.fa-plus-circle
            |  Add Stock

          a.btn(href='/sales/new')
            i.fas.fa-cash-register
            |  Record Sale

          a.btn(href='/reports')
            i.fas.fa-chart-pie
            |  Generate Report

          a.btn(href='/regicredit')
            i.fas.fa-user-plus
            |  Register Credit Customer

      // ================= DEPOSITS =================
      .section

        h2 Deposit Scheme

        table

          tr
            th Customer
            th Amount

          tr
            td John
            td UGX 50,000

          tr
            td Sarah
            td UGX 30,000

      // ================= USERS =================
      .section

        h2 User Management

        button.btn
          i.fas.fa-user-plus
          |  Add User

        table

          tr
            th Name
            th Role
            th Status

          tr
            td James
            td Sales Attendant
            td.success Active

          tr
            td Maria
            td Manager
            td.success Active